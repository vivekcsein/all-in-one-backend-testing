{
  "name": "all-in-one-backend-testing",
  "version": "1.0.0",
  "description": "testing out an all-in-one backend setup with express and vercel",
  "type": "commonjs",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc --project tsconfig.json && tsc-alias",
    "start": "node dist/api/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist .tsbuildinfo",
    "vercel-build": "bun run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@vercel/node": "^5.8.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
