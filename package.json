{
  "name": "hono-vercel-server",
  "version": "1.0.0",
  "description": "Hono TypeScript backend server on Vercel",
  "private": true,
  "engines": {
    "node": ">=20.x",
    "bun": ">=1.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "build": "tsc --project tsconfig.json && tsc-alias",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist .tsbuildinfo",
    "vercel-build": "bun run build"
  },
  "dependencies": {
    "hono": "^4.7.11",
    "zod": "^3.24.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^26.0.1",
    "tsc-alias": "^1.8.16",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.27.0"
  }
}
