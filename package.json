{
  "name": "all-in-one-backend-testing",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "rimraf dist && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --outDir dist",
    "start": "bun run dist/index.js"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@vercel/hono": "^0.2.101",
    "hono": "^4.12.27"
  }
}
