{
  "name": "all-in-one-backend-testing",
  "version": "1.0.0",
  "description": "testing out an all-in-one backend setup with express and vercel",
  "type": "module",
  "entry": "./dist/api/index.js",
  "main": "./dist/api/index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json && tsc-esm-fix --target='dist'",
    "clean": "rimraf dist",
    "start": "node dist/api/index.js",
    "start:local": "node dist/src/server.js",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@vercel/node": "^5.8.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsc-esm-fix": "^3.1.2",
    "tsx": "^4.21.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}
