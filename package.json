{
  "name": "all-in-one",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --watch --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json && tsc-esm-fix --target dist",
    "start": "node dist/src/server.js",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@vercel/node": "^5.7.13",
    "tsc-esm-fix": "^3.1.2",
    "typescript": "^6.0.3"
  }
}
