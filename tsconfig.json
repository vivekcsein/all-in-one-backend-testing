{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    /* ─── Strict Type Safety ──────────────────────────────────────── */
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "useUnknownInCatchVariables": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,

    /* ─── Target & Module ─────────────────────────────────────────── */
    /* CommonJS output (Node.js / Vercel serverless compatible)       */
    /* moduleResolution "bundler" is the forward-compatible upgrade   */
    /* path for CommonJS — Node10 is deprecated in TS 6.0 and will   */
    /* error in TS 7.0. TS PR #62320 explicitly allows this pair.     */
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],

    /* ─── Emit ────────────────────────────────────────────────────── */
    "outDir": "dist",
    "rootDir": "./",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": false,

    /* ─── Interop ─────────────────────────────────────────────────── */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    /* ─── Path Aliases ────────────────────────────────────────────── */
    /* tsc emits alias strings as-is into .js — tsc-alias rewrites    */
    /* them to relative paths post-compile so Node.js can resolve.    */

    /* ─── Performance ─────────────────────────────────────────────── */
    "skipLibCheck": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo"
  },
  "include": ["src/**/*", "api/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
